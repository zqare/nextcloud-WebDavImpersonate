		{
			"name": "Error Handling Tests",
			"item": [
				{
					"name": "Invalid Authentication",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Force clear all cookies and session data",
									"pm.cookies.clear();",
									"",
									"// Override collection auth with fixed invalid credentials",
									"pm.request.auth = {",
									"    type: 'basic',",
									"    basic: {",
									"        username: 'nonexistent-user',",
									"        password: 'fake-password-12345'",
									"    }",
									"};",
									"",
									"// Ensure no headers interfere with auth",
