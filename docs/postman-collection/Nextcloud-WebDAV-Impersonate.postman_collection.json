{
	"info": {
		"_postman_id": "nextcloud-webdav-impersonate-standalone",
		"name": "Nextcloud WebDAV Impersonate - Standalone",
		"description": "Complete standalone Postman collection for testing Nextcloud WebDAV with and without impersonation. All configuration is built-in - no environment files needed.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Standard WebDAV Tests (No Impersonation)",
			"item": [
				{
					"name": "PROPFIND - Get Root Directory",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 207 Multi-Status\", function () {",
									"    pm.response.to.have.status(207);",
									"});",
									"",
									"pm.test(\"Response contains WebDAV properties\", function () {",
									"    const responseText = pm.response.text();",
									"    pm.expect(responseText).to.include(\"d:propstat\");",
									"    pm.expect(responseText).to.include(\"d:prop\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PROPFIND",
						"header": [
							{
								"key": "Depth",
								"value": "1"
							},
							{
								"key": "Content-Type",
								"value": "application/xml"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<d:propfind xmlns:d=\"DAV:\">\n  <d:prop>\n    <d:displayname/>\n    <d:resourcetype/>\n    <d:getcontentlength/>\n    <d:getlastmodified/>\n  </d:prop>\n</d:propfind>"
						},
						"url": {
							"raw": "{{baseUrl}}/remote.php/dav/files/{{username}}/",
							"host": ["{{baseUrl}}"],
							"path": ["remote.php", "dav", "files", "{{username}}", ""]
						}
					},
					"response": []
				},
