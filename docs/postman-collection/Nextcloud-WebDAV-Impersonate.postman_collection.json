		{
			"name": "Impersonation WebDAV Tests",
			"item": [
				{
					"name": "PROPFIND - Get Impersonated Root Directory",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 207 Multi-Status\", function () {",
									"    pm.response.to.have.status(207);",
									"});",
									"",
									"pm.test(\"Impersonation header was sent\", function () {",
									"    const request = pm.request;",
									"    const impersonateHeader = request.headers.find(h => h.key.toLowerCase() === 'x-impersonate-user');",
									"    pm.expect(impersonateHeader).to.exist;",
									"    pm.expect(impersonateHeader.value).to.eql(pm.collectionVariables.get('impersonatedUser'));",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PROPFIND",
						"header": [
